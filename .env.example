# Copy this file to .env before using docker compose.
#
# Leave SMTP values blank to keep email-only controls hidden. BinderBridge still
# supports in-app notifications, manual invite links, and admin-assisted
# password recovery without SMTP.

BINDERBRIDGE_PUBLISHED_PORT=8000
BINDERBRIDGE_PUBLIC_BASE_URL=http://localhost:8000
BINDERBRIDGE_SOURCE_URL=https://github.com/thefatkid22/BinderBridge

# Optional SMTP settings for invite email, password recovery, and notification email.
BINDERBRIDGE_SMTP_HOST=
BINDERBRIDGE_SMTP_PORT=587
BINDERBRIDGE_SMTP_USERNAME=
BINDERBRIDGE_SMTP_PASSWORD=
BINDERBRIDGE_SMTP_FROM=
BINDERBRIDGE_SMTP_TLS=true
BINDERBRIDGE_SMTP_SSL=false
